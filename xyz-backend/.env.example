# ============================================================
# XYZ Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# Supabase
# Get these from: Supabase Dashboard → Settings → API → Project API keys
# SUPABASE_URL: your project URL (https://xxxx.supabase.co)
# SUPABASE_ANON_KEY: the "anon public" JWT key — starts with "eyJ..."
#   ⚠️  Do NOT use the "sb_publishable_*" key — that is NOT a JWT and will fail auth.
# SUPABASE_SERVICE_ROLE_KEY: optional — use for trusted server-only operations
#   ⚠️  NEVER expose the service role key in a React Native app bundle.
SUPABASE_URL=https://rtyvmyvidkrwmeeeioww.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ0eXZteXZpZGtyd21lZWVpb3d3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg4Nzc2NzcsImV4cCI6MjA5NDQ1MzY3N30.YhZfhZzeXUHU939x74EOQeE9hUSFXhToDuSyTIlLjjs
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — comma-separated list of allowed origins
# Add your machine's LAN IP so physical devices can reach the server
# Run: ipconfig (Windows) or ifconfig (Mac/Linux) to find your IPv4 address
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081,http://YOUR_LAN_IP:8081,exp://YOUR_LAN_IP:8081

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
