EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
EXPO_PUBLIC_CLOUDINARY_PRESET=xyz-unsigned

# Node.js backend base URL
# Use your machine's LAN IP — localhost does NOT work on a physical device
# Run `ipconfig` (Windows) or `ifconfig` (Mac/Linux) to find your IPv4 address
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1