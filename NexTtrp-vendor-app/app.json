{
  "expo": {
    "name": "Toureez Vendor",
    "slug": "toureez-vendor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "toureezvendor",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8631A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.toureez.vendor",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Toureez Vendor needs access to your photo library for package images.",
        "NSCameraUsageDescription": "Toureez Vendor needs access to your camera to capture package photos.",
        "NSPhotoLibraryAddUsageDescription": "Toureez Vendor saves package photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8631A"
      },
      "package": "com.toureez.vendor",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "toureezvendor"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E8631A",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Toureez Vendor needs access to your photo library for package images.",
          "cameraPermission": "Toureez Vendor needs access to your camera to capture package photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fefa804c-a565-47be-be8a-a6d1376252e1"
      }
    }
  }
}
