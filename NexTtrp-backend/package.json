{
  "name": "nexttrp-backend",
  "version": "1.0.0",
  "description": "Node.js backend for NEXTTRP travel package comparison app.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:api-client": "npm run build && node dist/scripts/testApiClient.js"
  },
  "keywords": [
    "travel",
    "express",
    "typescript",
    "supabase"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@sentry/node": "^10.55.0",
    "@supabase/supabase-js": "2.43.4",
    "@types/ws": "^8.18.1",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.5.5",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "eslint": "^9.9.1",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "@supabase/realtime-js": "2.8.4"
  }
}
