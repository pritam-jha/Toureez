# ============================================================
# XYZ Backend - Environment Variables
# ============================================================
# SUPABASE_ANON_KEY is the public "anon" JWT key.
# SUPABASE_SERVICE_ROLE_KEY is the private backend-only service role JWT key.
# Never put SUPABASE_SERVICE_ROLE_KEY in any frontend/admin Expo app.
# ============================================================

PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# Supabase
# Use the JWT "anon public" key from Supabase Dashboard → Settings → API → Project API keys
# It starts with "eyJ..." — NOT the "sb_publishable_*" key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
# ⚠️  REQUIRED for backend DB writes — get from Supabase Dashboard → Settings → API → service_role
# NEVER put this key in the React Native app. Backend only.
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# CORS — add your machine's LAN IP so physical Android/iOS devices can reach the server
# Replace with your actual LAN IP if it changes (run: ipconfig | findstr IPv4)
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081,http://localhost:8082,exp://localhost:8082

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Soft-launch / testing ─────────────────────────────────────────────────────
# Set to true to keep mock payment working even when NODE_ENV=production.
# Remove (or set to false) before real public launch with Razorpay integrated.
ENABLE_MOCK_PAYMENT=true

# Error monitoring (optional but recommended)
SENTRY_DSN=
