{
  "expo": {
    "name": "Toureez",
    "slug": "toureez-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B1426"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.toureez.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Toureez needs access to your photo library to upload profile pictures.",
        "NSCameraUsageDescription": "Toureez needs access to your camera to take profile pictures.",
        "NSPhotoLibraryAddUsageDescription": "Toureez saves photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.toureez.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "toureez"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E8631A",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 740,
          "resizeMode": "cover",
          "backgroundColor": "#0B1426"
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Toureez needs access to your photo library to upload profile pictures.",
          "cameraPermission": "Toureez needs access to your camera to take profile pictures."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "scheme": "toureez",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e8d1e31-52e4-4eff-b19c-5ee9e994c59a"
      }
    },
    "owner": "pritam1202"
  }
}
