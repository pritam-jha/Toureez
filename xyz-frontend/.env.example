# ============================================================
# XYZ App — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# All variables MUST be prefixed with EXPO_PUBLIC_ to be
# accessible in the Expo managed workflow client bundle.
# ============================================================

# Supabase — get these from Supabase Dashboard → Settings → API → Project API keys
# EXPO_PUBLIC_SUPABASE_ANON_KEY must be the JWT "anon public" key — starts with "eyJ..."
# ⚠️  Do NOT use the "sb_publishable_*" key — it is NOT a JWT and will fail auth.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key

# Cloudinary — get these from your Cloudinary dashboard
# The upload preset must be set to "Unsigned" in Cloudinary settings
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
EXPO_PUBLIC_CLOUDINARY_PRESET=xyz-unsigned

# Backend API base URL
# ⚠️  Use your machine's LAN IP — NOT localhost — when testing on a physical device.
# localhost resolves to the phone itself, not your dev machine.
# Run: ipconfig (Windows) or ifconfig (Mac/Linux) to find your IPv4 address.
EXPO_PUBLIC_API_BASE_URL=http://YOUR_LAN_IP:3000/api/v1
